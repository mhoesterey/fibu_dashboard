# Klardaten Gateway / Enterprise
KLARDATEN_API_BASE_URL=https://api.klardaten.com
KLARDATEN_ACCESS_TOKEN=__secret__
KLARDATEN_CLIENT_INSTANCE_ID=__uuid__
KLARDATEN_API_VARIANT=gateway

# Klardaten MCP, nur fuer KI-Agenten/Codex
KLARDATEN_MCP_URL=https://api.klardaten.com/mcp

# DATEV Online API, nur bei direkter DATEV-Integration
DATEV_ENV=sandbox
DATEV_CLIENT_ID=__secret_or_public_client_id__
DATEV_CLIENT_SECRET=__secret_if_confidential_client__
DATEV_REDIRECT_URI=http://localhost:3000/callback
DATEV_SCOPES=openid profile email __api_specific_scopes__
DATEV_OIDC_DISCOVERY_SANDBOX=https://login.datev.de/openidsandbox/.well-known/openid-configuration
DATEV_OIDC_DISCOVERY_PRODUCTION=https://login.datev.de/openid/.well-known/openid-configuration

# Fachlicher Kontext, falls fuer Requests erforderlich
DATEV_BERATERNUMMER=__optional__
DATEV_MANDANTENNUMMER=__optional__
DATEV_WIRTSCHAFTSJAHR=__optional__

# Betrieb / Zugriff / Logging
APP_OWNER_EMAILS=
APP_ADMIN_EMAILS=
HTTP_TIMEOUT_MS=30000
HTTP_RETRY_MAX_ATTEMPTS=3
HTTP_RETRY_BASE_DELAY_MS=500
HTTP_AUDIT_LOG_RETENTION_DAYS=14
LOG_LEVEL=info
